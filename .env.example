# Copy this file to .env and source it before running local deploy scripts.
# source .env
#
# Never commit .env — it is covered by .gitignore.
#
# Create a scoped API token at https://dash.cloudflare.com/profile/api-tokens
# Minimum required permissions:
#   Account > Cloudflare Workers Scripts > Edit
#   Account > Account Settings > Read

CLOUDFLARE_API_TOKEN="your-cloudflare-api-token"
CLOUDFLARE_ACCOUNT_ID="your-cloudflare-account-id"

# ---------------------------------------------------------------------------
# Preview deployments (npm run deploy:preview / delete:preview)
# ---------------------------------------------------------------------------
# Set to the pull request number you want to target.
# Example: PR_NUMBER=42 npm run deploy:preview

PR_NUMBER=""
