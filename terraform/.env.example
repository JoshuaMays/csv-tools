# Copy this file to .env and fill in your values.
# Source it before running Terraform or deploying: source terraform/.env
#
# Never commit .env — it is covered by .gitignore.
#
# These variables are read directly by wrangler for `npm run deploy`.
# For Terraform credentials, use terraform/terraform.tfvars instead.
#
# Create a scoped API token at https://dash.cloudflare.com/profile/api-tokens
# Minimum required permissions:
#   Account > Cloudflare Workers Scripts > Edit
#   Account > Account Settings > Read

export CLOUDFLARE_API_TOKEN="your-cloudflare-api-token"
export CLOUDFLARE_ACCOUNT_ID="your-cloudflare-account-id"
